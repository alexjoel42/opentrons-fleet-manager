# Dev proxy only: where `npm run dev` forwards `/api`. Set here, in `.env.local`, or in the shell (e.g. BACKEND_TARGET_URL=http://192.168.1.10:8000 npm run dev). Default: http://localhost:8000
# BACKEND_TARGET_URL=http://192.168.1.10:8000

# Base URL for the FastAPI backend (no trailing slash).
# Local fleet (Setup, robot cards): in `vite dev`, requests use /api via the proxy — you can
# leave this pointed at a deployed API for cloud mode; it does not affect local IP fleet calls.
# For `vite preview` or static hosting without a proxy, set this to your real API origin.
VITE_API_URL=http://localhost:8000

# Set to "true" to use cloud mode: login, labs, cloud robots, staleness UI.
# VITE_USE_CLOUD=true

# Vercel / production: set VITE_API_URL and VITE_USE_CLOUD in the host environment
# (Vercel → Project → Settings → Environment Variables), then redeploy so the bundle picks them up.
# Example: VITE_API_URL=https://your-service.onrender.com  VITE_USE_CLOUD=true

# Seconds after which robot data is considered stale (default 60).
# VITE_STALE_THRESHOLD_SECONDS=60

# Milliseconds between UI polls to the API (fleet snapshot, cloud robots, per-robot hooks). Default 60000.
# VITE_POLL_INTERVAL_MS=60000

# Optional: comma-separated list of robot IPs for the dashboard (backend).
# ROBOT_IPS=192.0.2.10,192.0.2.11

# Local fleet notes: default operator name when the browser does not send X-Notes-Operator (backend).
# NOTES_OPERATOR_NAME=Jane Doe

# Local fleet notes: browser sends this as X-Notes-Operator for compliance-style stamps (optional).
# VITE_NOTES_OPERATOR_NAME=Jane Doe
