# Base URL for the FastAPI backend (no trailing slash).
# In dev with Vite proxy, use "" or "/" so requests go to the same origin.
VITE_API_URL=http://localhost:8000

# Set to "true" to use cloud mode: login, labs, cloud robots, staleness UI.
# VITE_USE_CLOUD=true

# Seconds after which robot data is considered stale (default 60).
# VITE_STALE_THRESHOLD_SECONDS=60

# Optional: comma-separated list of robot IPs for the dashboard (backend).
# ROBOT_IPS=192.0.2.10,192.0.2.11
