# Dev proxy only: where `npm run dev` forwards `/api`. Set here, in `.env.local`, or in the shell
# (e.g. BACKEND_TARGET_URL=http://192.168.1.10:8000 npm run dev). Default: http://localhost:8000
# BACKEND_TARGET_URL=http://192.168.1.10:8000

# Base URL for the FastAPI backend (no trailing slash). Leave empty in dev to use the Vite proxy.
# For production static hosting without a proxy (unusual), set to your API origin.
# Raspberry Pi + nginx: leave empty so the built app uses same-origin `/api`.
# VITE_API_URL=

# Seconds after which robot data is considered stale in the UI (default 60).
# VITE_STALE_THRESHOLD_SECONDS=60

# Milliseconds between UI polls (fleet snapshot, per-robot hooks). Default 60000.
# VITE_POLL_INTERVAL_MS=60000

# Optional: comma-separated robot IPs for the backend when robot_ips.json is missing.
# ROBOT_IPS=192.0.2.10,192.0.2.11

# Local fleet notes: default operator name when the browser does not send X-Notes-Operator (backend).
# NOTES_OPERATOR_NAME=Jane Doe

# Local fleet notes: browser sends this as X-Notes-Operator for compliance-style stamps (optional).
# VITE_NOTES_OPERATOR_NAME=Jane Doe

# Fleet error ticket subprocess (abr_testing.data_collection.robot_fleet_error).
# Defaults target ~/ticket-creation on the fleet host (e.g. Raspberry Pi).
# ABR_REPO_ROOT is the cwd for the command; relative paths resolve against it (default: home).
# ABR_REPO_ROOT=~
# ABR_PYTHONPATH=~/ticket-creation/abr-testing
# ABR_ERRORS_DIR=~/ticket-creation/Errors
# ABR_PYTHON=python3
# ABR_TICKET_TIMEOUT=300
#
# Local dev: copy to .env, run `make setup-py` (PyPI deps) and optionally `make setup-abr` (pipenv sync).
# ABR_PYTHONPATH=/Users/you/Desktop/opentrons/abr-testing
# ABR_ERRORS_DIR=/Users/you/Desktop/Errors
# ABR_PYTHON=/Users/you/Desktop/opentrons/abr-testing/.venv/bin/python
# Project key (RABR vs RQA) is chosen automatically from the robot name (contains "ABR" → RABR).
